# -----------------------------------------------------------------------------
# AI Content Hub — environment variables
# Copy this file to .env and fill in real values. Never commit .env.
# -----------------------------------------------------------------------------

# --- Database (Neon Postgres) -------------------------------------------------
# Pooled connection string from the Neon dashboard (used by the app at runtime).
DATABASE_URL="postgresql://user:password@ep-example-12345.eu-central-1.aws.neon.tech/neondb?sslmode=require"
# Direct (non-pooled) connection string, used by Prisma Migrate.
DIRECT_URL="postgresql://user:password@ep-example-12345.eu-central-1.aws.neon.tech/neondb?sslmode=require"

# --- Auth.js -------------------------------------------------------------------
# Generate with: npx auth secret   (or: openssl rand -base64 32)
AUTH_SECRET=""
# Public URL of the deployment. Use http://localhost:3000 in development.
APP_URL="http://localhost:3000"

# --- Encryption ------------------------------------------------------------
# Used to encrypt stored third-party credentials (WordPress, GitHub, social
# tokens) at rest. Generate with: openssl rand -base64 32
ENCRYPTION_KEY=""

# --- AI provider (Anthropic) -------------------------------------------------
ANTHROPIC_API_KEY=""
AI_PROVIDER="anthropic"
AI_MODEL="claude-opus-4-8"
AI_MAX_TOKENS="2048"
AI_REQUEST_TIMEOUT="30000"

# --- GitHub integration (optional) ------------------------------------------
# Only needed if you want the GitHub integration's OAuth app flow later; the
# current version accepts a personal access token entered by the user instead.
GITHUB_CLIENT_ID=""
GITHUB_CLIENT_SECRET=""

# --- Scheduled tasks (Vercel Cron) -------------------------------------------
# Shared secret checked against the Authorization header on /api/cron/* routes.
CRON_SECRET=""

# --- Branding ----------------------------------------------------------------
NEXT_PUBLIC_APP_NAME="AI Content Hub"

# --- Optional / not required for the core app to run -------------------------
# STORAGE_PROVIDER=""
# EMAIL_PROVIDER=""
# SENTRY_DSN=""
